#include <stdio.h>
int main(){
    int a[50],n,i,key,l=0,r,mid;
    scanf("%d",&n);
    for(i=0;i<n;i++) scanf("%d",&a[i]);
    scanf("%d",&key);

    r=n-1;
    while(l<=r){
        mid=(l+r)/2;
        if(a[mid]==key){
            printf("Found");
            return 0;
        }
        else if(a[mid]<key)
            l=mid+1;
        else
            r=mid-1;
    }
    printf("Not Found");
}
